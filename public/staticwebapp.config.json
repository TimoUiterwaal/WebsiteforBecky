{
  "routes": [
    { "route": "/clicker", "rewrite": "/clicker.html" },
    { "route": "/memory",  "rewrite": "/memory.html"  },
    { "route": "/rhythm",  "rewrite": "/rhythm.html"  },
    { "route": "/trivia",  "rewrite": "/trivia.html"  },
    { "route": "/runner",  "rewrite": "/runner.html"  },
    { "route": "/menu",    "rewrite": "/menu.html"    },
    { "route": "/about",   "rewrite": "/about.html"   }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/fonts/*", "/sounds/*", "/images/*"]
  },
  "responseOverrides": {
    "404": { "rewrite": "/index.html", "statusCode": 200 }
  },
  "globalHeaders": {
    "Cache-Control": "public, max-age=31536000, immutable"
  },
  "mimeTypes": {
    ".ogg": "audio/ogg",
    ".webp": "image/webp"
  }
}
